{
  "manifest_version": 3,
  "name": "CDP Bridge",
  "version": "2.0.0",
  "description": "Chrome DevTools Protocol Bridge for Playwright/Puppeteer automation",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CDP Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["config-page-preview.html", "config-page.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
