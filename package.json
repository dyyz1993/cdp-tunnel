{
  "name": "cdp-tunnel",
  "version": "3.6.2",
  "description": "Bridge Chrome's debugger API to WebSocket — control your existing browser with Playwright/Puppeteer via CDP",
  "main": "server/proxy-server.js",
  "bin": {
    "cdp-tunnel": "./cli/index.js"
  },
  "scripts": {
    "start": "node server/proxy-server.js",
    "test:compare": "node tests/cdp-compare/cdp-compare-runner.js",
    "test": "node tests/e2e/run-all.js",
    "test:e2e": "node tests/e2e/run-all.js",
    "test:core": "SKIP_EXTENDED=1 node tests/e2e/run-all.js",
    "test:smoke": "ONLY=test-default-page,test-strict-isolation,test-no-user-tab-grab node tests/e2e/run-all.js",
    "prepare": "husky"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "cdp-proxy",
    "playwright",
    "puppeteer",
    "chrome-extension",
    "browser-automation",
    "web-scraping",
    "remote-debugging",
    "websocket",
    "testing",
    "browser-control"
  ],
  "author": "dyyz1993",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyyz1993/cdp-tunnel.git"
  },
  "homepage": "https://github.com/dyyz1993/cdp-tunnel#readme",
  "bugs": {
    "url": "https://github.com/dyyz1993/cdp-tunnel/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "server/",
    "cli/",
    "extension-new/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.0.0",
    "http-proxy": "^1.18.1",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "chrome-remote-interface": "^0.34.0",
    "husky": "^9.1.7",
    "playwright": "^1.58.2"
  }
}
