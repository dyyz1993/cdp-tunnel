{
  "manifest_version": 3,
  "name": "CDP Bridge",
  "version": "2.10.10",
  "description": "Chrome DevTools Protocol Bridge for Playwright/Puppeteer automation",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabGroups",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CDP Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "config-page-preview.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "config-page-preview.html",
        "config-page.js",
        "utils/config.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}